# =========================
# Python cache
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# =========================
# Python / Conda environments
# =========================
.conda/
.env/
.venv/
venv/
env/

# =========================
# Data files
# /data/ ignores the root local data directory.
# scripts/data/ contains data-processing scripts and is NOT ignored.
# =========================
/data/
/datasets/
raw_data/
processed_data/

# rMD17 raw and processed datasets (explicit, for clarity)
data/raw/
data/processed/
data/rmd17/
data/real_datasets/

# Seed data archive (large; already extracted into data/rmd17/)
deepmd-al-hpc-seed-data.tar.gz

# Nsight Systems traces (large profiling intermediates)
*.nsys-rep
*.sqlite
*.qdstrm

# GPU monitoring raw CSV (SM/power samples; aggregated in summary.json)
experiments/**/gpu.csv

# =========================
# DeePMD / model files
# =========================
model.ckpt*
checkpoint
*.pb
*.pth
*.pt
*.onnx
*.h5
*.hdf5

# =========================
# Large numerical files
# =========================
*.npy
*.npz

# =========================
# Logs
# =========================
logs/
*.log
runs/
wandb/
events.out.tfevents*

# =========================
# LAMMPS / MD outputs
# =========================
dump.*
traj.*
log.lammps
*.lammpstrj
*.xyz
*.xtc
*.dcd

# =========================
# System files
# =========================
.DS_Store
Thumbs.db

# =========================
# DeePMD generated training outputs
# =========================
lcurve.out
out.json
input_v2_compat.json

# =========================
# Local experiment outputs
# (top-level patterns like *.pb, *.npz, checkpoint, model.ckpt*, *.log
#  already cover individual files; directory-level ignores below are
#  for performance — git skips scanning these dirs entirely.)
# =========================
experiments/**/committee_predictions.npz
experiments/**/committee_models/
experiments/**/model_*/

# Profiling logs (large, auto-generated)
experiments/profiling/*.log
experiments/profiling/gpu_*.csv
experiments/profiling/batch_size_scaling.csv
experiments/profiling/benzene_bs*.npz
experiments/profiling/benzene_prediction_test.npz
experiments/profiling/gpu_dmon_benzene_prediction*
experiments/profiling/v100/gpu_logs/

# Large training artifacts
experiments/**/frozen_model.pb
experiments/**/*.npz
experiments/**/*.npy
experiments/**/model.ckpt*
experiments/**/checkpoint*
experiments/**/out.json
experiments/**/test_result.*

# DeePMD test output details
experiments/*_test_model*.out
experiments/*_test_model*.e.out
experiments/*_test_model*.f.out
experiments/*_test_model*.v.out
experiments/*_test_model*.e_peratom.out
experiments/*_test_model*.v_peratom.out

# Editor temporary files
*.swp
*.swo
.*.swp
